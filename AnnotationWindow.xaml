<Window x:Class="PixtechApplication.AnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Character Annotation Tool" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✏️" FontSize="24" Margin="0,0,10,0"/>
                    <TextBlock Text="Character Annotation Tool" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtImageName" Text="" FontSize="14" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="txtAnnotationCount" Text="Annotations: 0" FontSize="14" Margin="0,0,20,0"/>
                    <Button x:Name="btnSaveAnnotations" Content="💾 Save All" Width="120" Height="35" 
                            Background="#28A745" Foreground="White" Click="SaveAnnotations_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Image Canvas Area -->
            <Border Background="White" BorderBrush="#DDD" BorderThickness="1">
                <Grid>
                    <ScrollViewer x:Name="scrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="imageCanvas" 
                                Background="#F9F9F9"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                MouseMove="Canvas_MouseMove"
                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
                            <Image x:Name="annotationImage" 
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right Panel -->
            <Border Grid.Column="1" Background="White" Padding="15" Margin="10,0,0,0" BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="ANNOTATION LIST" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Annotations List -->
                    <Border Background="#F9F9F9" Height="400" BorderBrush="#DDD" BorderThickness="1">
                        <ListBox x:Name="lstAnnotations" 
                                 SelectionChanged="Annotations_SelectionChanged"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" Padding="10" Margin="5" BorderBrush="#DDD" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="{Binding BoundsText}" FontSize="11" Foreground="#666" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="🗑️" Width="30" Height="30" 
                                                    Background="#DC3545" Foreground="White"
                                                    Tag="{Binding}" Click="DeleteAnnotation_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Tools -->
                    <TextBlock Text="TOOLS" FontWeight="Bold" FontSize="14" Margin="0,20,0,10"/>
                    <Button Content="🔍 Zoom In" Height="35" Margin="0,5" Click="ZoomIn_Click"/>
                    <Button Content="🔍 Zoom Out" Height="35" Margin="0,5" Click="ZoomOut_Click"/>
                    <Button Content="↺ Reset View" Height="35" Margin="0,5" Click="ResetView_Click"/>
                    <Button Content="🗑️ Clear All" Height="35" Margin="0,15" 
                            Background="#DC3545" Foreground="White" Click="ClearAll_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom Controls -->
        <Border Grid.Row="2" Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Character Label:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="txtCharLabel" Width="200" Height="35" FontSize="16" 
                             VerticalContentAlignment="Center" MaxLength="5"
                             KeyDown="CharLabel_KeyDown"/>
                    <TextBlock Text="(Draw rectangle, then type character)" 
                               VerticalAlignment="Center" Margin="15,0,0,0" 
                               Foreground="#666" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⬅️ Previous" Width="120" Height="40" Margin="5" Click="PreviousImage_Click"/>
                    <Button Content="Next ➡️" Width="120" Height="40" Margin="5" Click="NextImage_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="10">
            <TextBlock x:Name="txtStatus" Text="Draw a rectangle on the image, then type the character label" 
                       Foreground="White" FontSize="11"/>
        </Border>
    </Grid>
</Window>