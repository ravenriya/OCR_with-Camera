<Window x:Class="CognexStyleApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixTech Authentication" 
        Height="680" Width="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="20" BorderBrush="#0078D4" BorderThickness="3">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#60000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0078D4" CornerRadius="20,20,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🔐" FontSize="35" HorizontalAlignment="Center"/>
                    <TextBlock Text="PixTech Deep Learning" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="1" Margin="0" BorderThickness="0" FontSize="13">

                <TabItem Header="LOGIN" FontSize="14" FontWeight="Bold" Padding="20,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="40,20,40,30">
                            <TextBlock Text="Username" FontSize="12" Foreground="#555" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <Border BorderBrush="#CCC" BorderThickness="2" CornerRadius="5">
                                <TextBox x:Name="txtLoginUsername" Height="40" FontSize="14" Padding="10" BorderThickness="0"/>
                            </Border>

                            <TextBlock Text="Password" FontSize="12" Foreground="#555" Margin="0,15,0,5" FontWeight="SemiBold"/>
                            <Border BorderBrush="#CCC" BorderThickness="2" CornerRadius="5">
                                <PasswordBox x:Name="txtLoginPassword" Height="40" FontSize="14" Padding="10" BorderThickness="0" KeyDown="TxtLoginPassword_KeyDown"/>
                            </Border>

                            <TextBlock x:Name="txtLoginError" Text="" Foreground="Red" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap" FontWeight="SemiBold"/>

                            <Button Content="LOGIN" Height="45" Background="#28A745" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Margin="0,20,0,0" Click="BtnLogin_Click" Cursor="Hand"/>
                            <Button Content="EXIT" Height="45" Background="#6C757D" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Margin="0,8,0,0" Click="BtnExit_Click" Cursor="Hand"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="SIGNUP" FontSize="14" FontWeight="Bold" Padding="20,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="40,20,40,30">
                            <TextBlock Text="Create New Account" FontSize="15" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,15"/>

                            <TextBlock Text="Username" FontSize="12" Foreground="#555" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <Border BorderBrush="#CCC" BorderThickness="2" CornerRadius="5">
                                <TextBox x:Name="txtSignupUsername" Height="40" FontSize="14" Padding="10" BorderThickness="0"/>
                            </Border>

                            <TextBlock Text="Password" FontSize="12" Foreground="#555" Margin="0,15,0,5" FontWeight="SemiBold"/>
                            <Border BorderBrush="#CCC" BorderThickness="2" CornerRadius="5">
                                <PasswordBox x:Name="txtSignupPassword" Height="40" FontSize="14" Padding="10" BorderThickness="0" PasswordChanged="TxtSignupPassword_Changed"/>
                            </Border>

                            <StackPanel Margin="0,5,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="strength1" Height="4" Background="#E0E0E0" Margin="0,0,2,0" CornerRadius="2"/>
                                    <Border x:Name="strength2" Grid.Column="1" Height="4" Background="#E0E0E0" Margin="2,0" CornerRadius="2"/>
                                    <Border x:Name="strength3" Grid.Column="2" Height="4" Background="#E0E0E0" Margin="2,0" CornerRadius="2"/>
                                    <Border x:Name="strength4" Grid.Column="3" Height="4" Background="#E0E0E0" Margin="2,0,0,0" CornerRadius="2"/>
                                </Grid>
                                <TextBlock x:Name="txtPasswordStrength" Text="" FontSize="10" Foreground="#666" Margin="0,3,0,0"/>
                            </StackPanel>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Password Requirements:" FontSize="11" FontWeight="SemiBold" Foreground="#555"/>
                                <TextBlock x:Name="req1" Text="❌ At least 8 characters" FontSize="10" Foreground="#999" Margin="0,3,0,0"/>
                                <TextBlock x:Name="req2" Text="❌ Uppercase letter (A-Z)" FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                                <TextBlock x:Name="req3" Text="❌ Lowercase letter (a-z)" FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                                <TextBlock x:Name="req4" Text="❌ Number (0-9)" FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                                <TextBlock x:Name="req5" Text="❌ Special character" FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Confirm Password" FontSize="12" Foreground="#555" Margin="0,15,0,5" FontWeight="SemiBold"/>
                            <Border BorderBrush="#CCC" BorderThickness="2" CornerRadius="5">
                                <PasswordBox x:Name="txtSignupConfirm" Height="40" FontSize="14" Padding="10" BorderThickness="0"/>
                            </Border>

                            <TextBlock x:Name="txtSignupError" Text="" Foreground="Red" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap" FontWeight="SemiBold"/>

                            <Button Content="CREATE ACCOUNT" Height="45" Background="#007BFF" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Margin="0,15,0,0" Click="BtnSignup_Click" Cursor="Hand"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</Window>