<Window x:Class="PixtechApplication.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixTech — Sign In"
        Height="600" Width="460"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#DDE0E8" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270"
                              Color="#000000" Opacity="0.12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="#1A1D23" CornerRadius="8,8,0,0" Padding="32,24,32,22">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="4" Background="#E8B000" Margin="0,0,14,0">
                        <TextBlock Text="P" Foreground="#1A1D23" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PixTech Deep Learning" Foreground="#FFFFFF"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Sign in to your workspace" Foreground="#6A7080"
                                   FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- TAB CONTROL -->
            <TabControl Grid.Row="1" Margin="0" BorderThickness="0" Background="#FFFFFF" FontSize="13">

                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="tb" Background="Transparent"
                                            BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                            Padding="0,12,0,10" Margin="0">
                                        <ContentPresenter HorizontalAlignment="Center" ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="tb" Property="BorderBrush" Value="#E8B000"/>
                                            <Setter Property="Foreground" Value="#7A5800"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="#9098AA"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#5A6070"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background" Value="#F7F8FA"/>
                    </Style>
                </TabControl.Resources>

                <!-- LOGIN TAB -->
                <TabItem Header="Login" FontSize="13" Padding="32,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                        <StackPanel Margin="32,22,32,28">

                            <TextBlock Text="Username" Foreground="#5A6070" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border BorderBrush="#DDE0E8" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                                <TextBox x:Name="txtLoginUsername" Height="40" FontSize="13"
                                         Padding="12,0" BorderThickness="0" Background="Transparent"
                                         Foreground="#1A1D23" VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Password" Foreground="#5A6070" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border BorderBrush="#DDE0E8" BorderThickness="1" CornerRadius="4" Margin="0,0,0,4">
                                <PasswordBox x:Name="txtLoginPassword" Height="40" FontSize="13"
                                             Padding="12,0" BorderThickness="0" Background="Transparent"
                                             Foreground="#1A1D23" VerticalContentAlignment="Center"
                                             KeyDown="TxtLoginPassword_KeyDown"/>
                            </Border>

                            <TextBlock x:Name="txtLoginError" Text="" Foreground="#D63B3B"
                                       FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" FontWeight="SemiBold"/>

                            <Button Content="LOGIN" Height="42" Margin="0,20,0,0"
                                    Background="#1A1D23" Foreground="#E8B000"
                                    FontSize="13" FontWeight="Bold" BorderThickness="0"
                                    Cursor="Hand" Click="BtnLogin_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#2A2D35"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="Exit" Height="38" Margin="0,8,0,0"
                                    Background="#F7F8FA" Foreground="#5A6070"
                                    FontSize="12" FontWeight="SemiBold"
                                    BorderBrush="#DDE0E8" BorderThickness="1"
                                    Cursor="Hand" Click="BtnExit_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#ECEEF2"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#C8CCD8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- SIGNUP TAB -->
                <TabItem Header="Sign Up" FontSize="13" Padding="32,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                        <StackPanel Margin="32,22,32,28">

                            <TextBlock Text="Create a new account" Foreground="#9098AA"
                                       FontSize="12" Margin="0,0,0,18"/>

                            <TextBlock Text="Username" Foreground="#5A6070" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border BorderBrush="#DDE0E8" BorderThickness="1" CornerRadius="4" Margin="0,0,0,16">
                                <TextBox x:Name="txtSignupUsername" Height="40" FontSize="13"
                                         Padding="12,0" BorderThickness="0" Background="Transparent"
                                         Foreground="#1A1D23" VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Password" Foreground="#5A6070" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border BorderBrush="#DDE0E8" BorderThickness="1" CornerRadius="4" Margin="0,0,0,6">
                                <PasswordBox x:Name="txtSignupPassword" Height="40" FontSize="13"
                                             Padding="12,0" BorderThickness="0" Background="Transparent"
                                             Foreground="#1A1D23" VerticalContentAlignment="Center"/>
                            </Border>

                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="strength1" Grid.Column="0" Height="3" Background="#ECEEF2" Margin="0,0,3,0" CornerRadius="2"/>
                                <Border x:Name="strength2" Grid.Column="1" Height="3" Background="#ECEEF2" Margin="3,0" CornerRadius="2"/>
                                <Border x:Name="strength3" Grid.Column="2" Height="3" Background="#ECEEF2" Margin="3,0" CornerRadius="2"/>
                                <Border x:Name="strength4" Grid.Column="3" Height="3" Background="#ECEEF2" Margin="3,0,0,0" CornerRadius="2"/>
                            </Grid>
                            <TextBlock x:Name="txtPasswordStrength" Text="" FontSize="10"
                                       Foreground="#9098AA" Margin="0,3,0,12"/>

                            <Border Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="1"
                                    CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Requirements" Foreground="#5A6070" FontSize="11"
                                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="req1" Text="✗  At least 8 characters"  FontSize="11" Foreground="#C8CCD8" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="req2" Text="✗  Uppercase letter (A-Z)"  FontSize="11" Foreground="#C8CCD8" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="req3" Text="✗  Lowercase letter (a-z)"  FontSize="11" Foreground="#C8CCD8" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="req4" Text="✗  Number (0-9)"             FontSize="11" Foreground="#C8CCD8" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="req5" Text="✗  Special character"        FontSize="11" Foreground="#C8CCD8" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Confirm Password" Foreground="#5A6070" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border BorderBrush="#DDE0E8" BorderThickness="1" CornerRadius="4" Margin="0,0,0,4">
                                <PasswordBox x:Name="txtSignupConfirm" Height="40" FontSize="13"
                                             Padding="12,0" BorderThickness="0" Background="Transparent"
                                             Foreground="#1A1D23" VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="txtSignupError" Text="" Foreground="#D63B3B"
                                       FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" FontWeight="SemiBold"/>

                            <Button Content="CREATE ACCOUNT" Height="42" Margin="0,18,0,0"
                                    Background="#1A1D23" Foreground="#E8B000"
                                    FontSize="13" FontWeight="Bold" BorderThickness="0"
                                    Cursor="Hand" Click="BtnSignup_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#2A2D35"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</Window>