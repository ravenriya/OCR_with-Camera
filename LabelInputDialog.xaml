<Window x:Class="PixtechApplication.LabelInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Character Label" 
        Height="180" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Enter the character for this region:" 
                   FontSize="14" FontWeight="Bold" 
                   Foreground="#333"/>
        <Border Grid.Row="1" BorderBrush="#2196F3" BorderThickness="2" 
                CornerRadius="5" Margin="0,15,0,0" Background="White">
            <TextBox x:Name="txtLabel" Height="50" FontSize="24" FontWeight="Bold"
                     TextAlignment="Center" MaxLength="1"
                     BorderThickness="0"
                     VerticalContentAlignment="Center"/>
        </Border>
        <TextBlock Grid.Row="2" Text="(Press Enter or click OK)" 
                   FontSize="10" Foreground="Gray" Margin="0,8,0,0"
                   HorizontalAlignment="Center" FontStyle="Italic"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="✅ OK" Width="90" Height="38" IsDefault="True" 
                    Click="OK_Click"
                    Background="#4CAF50" Foreground="White" 
                    FontWeight="Bold" FontSize="13"/>
            <Button Content="❌ Cancel" Width="90" Height="38" IsCancel="True" 
                    Click="Cancel_Click"
                    Margin="10,0,0,0"
                    Background="#9E9E9E" Foreground="White" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>