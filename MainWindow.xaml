<Window x:Class="PixtechApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixTech OCR Studio"
        Height="860" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing"
        Background="#FAF9F6"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>

        <!-- ============ PALETTE ============ -->
        <!--<SolidColorBrush x:Key="BrushBg"            Color="#FAF9F6"/>
        <SolidColorBrush x:Key="BrushSurface"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt"     Color="#6E6A5F"/>
