<Window x:Class="PixtechApplication.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="PixTech Deep Learning Studio" 
            Height="900" Width="1600"
            WindowStartupLocation="CenterScreen"
            Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🎯" FontSize="30" Margin="0,0,15,0"/>
                    <TextBlock Text="PixTech Deep Learning Studio" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border Background="#FFA500" CornerRadius="3" Padding="8,4" Margin="15,0,0,0">
                        <TextBlock x:Name="txtMode" Text="INFERENCE MODE" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Control Panel -->
        <Border Grid.Row="1" Background="White" Padding="20,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- File Loading -->
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Button x:Name="btnLoadFiles" Content="📁 Load Files" Width="150" Height="40" Margin="5" 
                                Background="#0078D4" Foreground="White" FontWeight="Bold" Click="LoadFiles_Click"/>
                    <Button x:Name="btnLoadFolder" Content="📂 Load Folder" Width="150" Height="40" Margin="5" 
                                Background="#0078D4" Foreground="White" FontWeight="Bold" Click="LoadFolder_Click"/>
                    <!-- Add this button in your Training Mode panel, after the existing "Annotate" button -->

                    <Button x:Name="btnAutoDetect"
        Content="🤖 Auto-Detect Characters (CRAFT)"
        Width="220"
        Height="40"
        Margin="5"
        Background="#FF2196F3"
        Foreground="White"
        FontWeight="Bold"
        FontSize="14"
        Click="AutoDetectCharacters_Click"
        ToolTip="Automatically detect character regions using CRAFT AI"/>
                    <TextBlock Text="Tool:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbToolType" Width="200" Height="35" Margin="5" SelectionChanged="ToolType_SelectionChanged">
                        <ComboBoxItem Content="OCR" IsSelected="True"/>
                        <ComboBoxItem Content="Defects"/>
                        <ComboBoxItem Content="Classification"/>
                    </ComboBox>
                </StackPanel>

                <!-- Mode Selection -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,10">
                    <Border BorderBrush="#DDD" BorderThickness="2" CornerRadius="5" Padding="15,10" Background="#F9F9F9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MODE:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="13"/>
                            <RadioButton x:Name="rbInferenceMode" Content="🔍 Inference Mode" 
                                             GroupName="Mode" IsChecked="True" 
                                             VerticalAlignment="Center" Margin="5,0,20,0" FontSize="13"
                                             Checked="ModeChanged"/>
                            <RadioButton x:Name="rbTrainingMode" Content="🎓 Training Mode" 
                                             GroupName="Mode" 
                                             VerticalAlignment="Center" Margin="5,0" FontSize="13"
                                             Checked="ModeChanged"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Training Mode Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,10">
                    <Button x:Name="btnAnnotate" Content="✏️ Annotate Images" Width="150" Height="40" 
                                Margin="5,0" Background="#17A2B8" Foreground="White" FontWeight="Bold"
                                Click="Annotate_Click" IsEnabled="False" Visibility="Collapsed"/>
                    <Button x:Name="btnStartTraining" Content="🚀 Start Training" Width="150" Height="40" 
                                Margin="5,0" Background="#28A745" Foreground="White" FontWeight="Bold"
                                Click="StartTraining_Click" IsEnabled="False" Visibility="Collapsed"/>
                    <Button x:Name="btnCheckAnnotations" Content="📊 Check Annotations" Width="150" Height="40" 
                                Margin="5,0" Background="#6C757D" Foreground="White" FontWeight="Bold"
                                Click="CheckAnnotations_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Image List -->
            <Border Background="White" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="📋 Images" FontWeight="Bold" FontSize="14"/>
                    <ListBox x:Name="lstImages" Grid.Row="1" SelectionChanged="ImageList_SelectionChanged" Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- Image Display with Annotation Overlay -->
            <Border Grid.Column="1" Background="White" Padding="15" Margin="5,0" BorderBrush="#DDD" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖼️ Image Display" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtAnnotationMode" Text="" 
                           Foreground="Orange" FontWeight="Bold" 
                           Margin="15,0,0,0" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Image Container with Canvas Overlay -->
                    <Border Grid.Row="1" Background="#F0F0F0" Margin="0,10,0,0" 
                    BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <!-- Placeholder -->
                            <TextBlock x:Name="txtPlaceholder" Text="Load images to begin" 
                               FontSize="20" Foreground="#AAA" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Image -->
                            <Image x:Name="imgDisplay" Stretch="Uniform" Visibility="Collapsed"/>

                            <!-- Annotation Canvas Overlay -->
                            <Canvas x:Name="annotationCanvas" 
                            Background="Transparent"
                            Visibility="Collapsed"
                            MouseLeftButtonDown="AnnotationCanvas_MouseDown"
                            MouseMove="AnnotationCanvas_MouseMove"
                            MouseLeftButtonUp="AnnotationCanvas_MouseUp"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Panel -->
            <Border Grid.Column="2" Background="White" Padding="15" BorderBrush="#DDD" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Inference Panel -->
                        <StackPanel x:Name="pnlInference">
                            <TextBlock Text="🔍 INFERENCE" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="txtStatus" Text="Using ImprovedCharacterCNN (PyTorch custom model)..." Margin="0,10" FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                            <Button x:Name="btnRunInference" Content="▶️ RUN INFERENCE" Height="45" Margin="0,10" 
                                        Background="#28A745" Foreground="White" FontWeight="Bold" Click="RunInference_Click"/>
                            <ProgressBar x:Name="progressBar" Height="25" Value="0" Margin="0,10"/>

                            <TextBlock Text="📊 RESULTS" FontWeight="Bold" Margin="0,20,0,10" FontSize="14"/>
                            <Border Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="txtResult" Text="---" FontSize="16" 
                                                   Foreground="Blue" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="txtConfidence" Text="Confidence: ---" 
                                                   FontSize="12" Margin="0,5"/>
                                    <TextBlock x:Name="txtDecision" Text="---" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Button Content="✅ Accept" Height="40" Background="#28A745" 
                                            Foreground="White" FontWeight="Bold" Click="Accept_Click"/>
                                <Button Grid.Column="1" Content="❌ Reject" Height="40" 
                                            Background="#DC3545" Foreground="White" FontWeight="Bold"
                                            Margin="5,0,0,0" Click="Reject_Click"/>
                            </Grid>

                            <Separator Margin="0,20"/>

                            <TextBlock Text="💾 MODEL" FontWeight="Bold" Margin="0,10,0,10" FontSize="14"/>
                            <Button x:Name="btnSaveModel" Content="💾 Save Model" Height="35" Margin="0,5" Click="SaveModel_Click"/>
                            <Button x:Name="btnLoadModel" Content="📂 Load Model" Height="35" Margin="0,5" Click="LoadModel_Click"/>
                        </StackPanel>

                        <!-- Training Panel -->
                        <StackPanel x:Name="pnlTraining" Visibility="Collapsed">
                            <TextBlock Text="🎓 TRAINING SETUP" FontWeight="Bold" FontSize="14"/>

                            <!-- Annotation Status -->
                            <TextBlock Text="Annotation Status:" Margin="0,15,0,5" FontWeight="Bold" FontSize="12"/>
                            <Border Background="#FFF3CD" Padding="12" BorderBrush="#FFC107" BorderThickness="2" CornerRadius="5" Margin="0,5,0,10">
                                <TextBlock x:Name="txtAnnotationStatus" 
                                           Text="❌ No annotations" 
                                           FontSize="12" 
                                           Foreground="#856404" 
                                           TextWrapping="Wrap"
                                           LineHeight="18"/>
                            </Border>

                            <!-- BIG START TRAINING BUTTON -->
                            <Button x:Name="btnStartTrainingBig" 
                                      Content="🚀 START TRAINING NOW" 
                                      Height="60" 
                                      Background="#28A745" 
                                      Foreground="White" 
                                      FontWeight="Bold"
                                      FontSize="16"
                                      Margin="0,10,0,15"
                                      Click="StartTraining_Click"
                                      IsEnabled="False"/>

                            <!-- Quick Action Buttons -->
                            <Grid Margin="0,5,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Content="✏️ Annotate" 
                                        Height="40" 
                                        Background="#17A2B8" 
                                        Foreground="White" 
                                        FontWeight="Bold"
                                        Click="Annotate_Click"
                                        Margin="0,0,5,0"/>

                                <Button Grid.Column="1" 
                                        Content="🔄 Refresh" 
                                        Height="40" 
                                        Background="#6C757D" 
                                        Foreground="White" 
                                        FontWeight="Bold"
                                        Click="CheckAnnotations_Click"
                                        Margin="5,0,0,0"/>
                            </Grid>

                            <!-- ANNOTATION MANAGEMENT BUTTONS -->
                            <TextBlock Text="🔧 Annotation Tools:" FontWeight="Bold" Margin="0,10,0,5" FontSize="12"/>
                            <Button Content="🔧 Fix Mixed Annotations" 
                                    Background="#FF9800" Foreground="White" FontWeight="Bold"
                                    Height="40" Margin="0,0,0,5" 
                                    Click="SeparateAnnotations_Click"
                                    ToolTip="Separate annotations that got mixed between images"/>

                            <Button Content="🗑️ Clear CURRENT Image Only" 
                                    Background="#FFC107" Foreground="Black" FontWeight="Bold"
                                    Height="40" Margin="0,0,0,5" 
                                    Click="ClearCurrentImageAnnotations_Click"
                                    ToolTip="Delete annotations for the current image only"/>

                            <Button Content="🗑️ Clear ALL Annotations" 
                                    Background="#DC3545" Foreground="White" FontWeight="Bold"
                                    Height="40" Margin="0,0,0,10" 
                                    Click="ClearAllAnnotations_Click"
                                    ToolTip="Delete ALL annotations from ALL images"/>
                            

                            <Separator Margin="0,10,0,15"/>

                            <!-- Training Parameters -->
                            <TextBlock Text="Training Parameters:" Margin="0,5,0,10" FontWeight="Bold" FontSize="12"/>
                            <Border Background="#F9F9F9" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Epochs:" VerticalAlignment="Center" Margin="0,5" FontSize="11"/>
                                    <TextBox x:Name="txtEpochs" Grid.Column="1" Text="50" Height="28" 
                                                 Margin="5" VerticalContentAlignment="Center" FontSize="11"/>

                                    <TextBlock Grid.Row="1" Text="Batch Size:" VerticalAlignment="Center" Margin="0,5" FontSize="11"/>
                                    <TextBox x:Name="txtBatchSize" Grid.Row="1" Grid.Column="1" Text="32" Height="28" 
                                                 Margin="5" VerticalContentAlignment="Center" FontSize="11"/>

                                    <TextBlock Grid.Row="2" Text="Learn Rate:" VerticalAlignment="Center" Margin="0,5" FontSize="11"/>
                                    <TextBox x:Name="txtLearningRate" Grid.Row="2" Grid.Column="1" Text="0.001" Height="28" 
                                                 Margin="5" VerticalContentAlignment="Center" FontSize="11"/>
                                </Grid>
                            </Border>

                            <!-- Training Progress -->
                            <ProgressBar x:Name="progressBarTraining" Height="20" Value="0" Margin="0,15,0,5"/>
                            <TextBlock x:Name="txtTrainingStatus" Text="Ready to train..." FontSize="10" 
                                           Foreground="#666" Margin="0,0,0,10" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="White" FontSize="11" Margin="0,0,20,0"/>
                <TextBlock x:Name="txtImageCount" Text="Images: 0" Foreground="White" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>