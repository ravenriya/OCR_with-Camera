<Window x:Class="PixtechApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixTech OCR Studio"
        Height="860" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F7F8FA"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#1A1D23"/>
            <Setter Property="Foreground"      Value="#E8B000"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2D35"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#DDDFE5"/>
                                <Setter Property="Foreground" Value="#9098AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#5A6070"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#DDE0E8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#F7F8FA"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#C8CCD8"/>
                                <Setter Property="Foreground" Value="#1A1D23"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F0F1F4"/>
                                <Setter Property="Foreground" Value="#C8CCD8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background"      Value="#18A058"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14834A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#DDDFE5"/>
                                <Setter Property="Foreground" Value="#9098AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnWarn" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#B05A00"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#F0C830"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FEF9EC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#D63B3B"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#F5C0C0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FDF0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioMode" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#5A6070"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Padding"    Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#1A1D23"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtClean" TargetType="TextBox">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#1A1D23"/>
            <Setter Property="BorderBrush"     Value="#DDE0E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8B000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LbClean" TargetType="ListBox">
            <Setter Property="Background"      Value="#FFFFFF"/>
            <Setter Property="Foreground"      Value="#5A6070"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="LbItem" TargetType="ListBoxItem">
            <Setter Property="Foreground"               Value="#5A6070"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="12,8"/>
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#DDE0E8" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F7F8FA"/>
                                <Setter Property="Foreground" Value="#1A1D23"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#FEF9EC"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F0C830"/>
                                <Setter Property="Foreground"  Value="#7A5800"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PbAmber" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Background"      Value="#ECEEF2"/>
            <Setter Property="Foreground"      Value="#E8B000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left" CornerRadius="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DDE0E8" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="30" Height="30" CornerRadius="4" Background="#1A1D23" Margin="0,0,10,0">
                        <TextBlock Text="P" Foreground="#E8B000" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PixTech" Foreground="#1A1D23" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="OCR Studio" Foreground="#9098AA" FontSize="10"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#F0F1F4" BorderBrush="#DDE0E8" BorderThickness="1"
                        CornerRadius="4" Height="34" Width="290" HorizontalAlignment="Center" Padding="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" x:Name="rbInferenceMode" Content="Inference Mode"
                                     GroupName="AppMode" IsChecked="True" Checked="ModeChanged"
                                     Style="{StaticResource RadioMode}"
                                     HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <RadioButton Grid.Column="1" x:Name="rbTrainingMode" Content="Training Mode"
                                     GroupName="AppMode" Checked="ModeChanged"
                                     Style="{StaticResource RadioMode}"
                                     HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#FEF9EC" BorderBrush="#F0C830" BorderThickness="1"
                        CornerRadius="4" Padding="12,5" VerticalAlignment="Center">
                    <TextBlock x:Name="txtMode" Text="INFERENCE MODE"
                               Foreground="#7A5800" FontSize="10" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Button x:Name="btnLoadFiles"  Content="Load Files"   Style="{StaticResource BtnGhost}" Click="LoadFiles_Click"  Margin="0,0,6,0" Padding="12,0"/>
                <Button x:Name="btnLoadFolder" Content="Load Folder"  Style="{StaticResource BtnGhost}" Click="LoadFolder_Click" Margin="0,0,14,0" Padding="12,0"/>
                <Border Width="1" Height="18" Background="#DDE0E8" Margin="0,0,14,0"/>
                <Button x:Name="btnAnnotate"         Content="Annotate"       Style="{StaticResource BtnGhost}"   Click="Annotate_Click"         Visibility="Collapsed" IsEnabled="False" Margin="0,0,6,0"/>
                <Button x:Name="btnCheckAnnotations" Content="Refresh"         Style="{StaticResource BtnGhost}"   Click="CheckAnnotations_Click" Visibility="Collapsed" Margin="0,0,6,0"/>
                <Button x:Name="btnStartTraining"    Content="Start Training"  Style="{StaticResource BtnPrimary}" Click="StartTraining_Click"    Visibility="Collapsed" IsEnabled="False" Padding="16,0"/>
            </StackPanel>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="160"/>
                <ColumnDefinition Width="*"   MinWidth="300"/>
                <ColumnDefinition Width="300" MinWidth="260" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#DDE0E8" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGES" Foreground="#9098AA" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="lstImages"
                             Style="{StaticResource LbClean}"
                             ItemContainerStyle="{StaticResource LbItem}"
                             SelectionChanged="ImageList_SelectionChanged"/>
                    <Border Grid.Row="2" Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="0,1,0,0" Padding="14,0">
                        <TextBlock x:Name="txtImageCount" Text="0 images" Foreground="#9098AA" FontSize="10" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- CENTER -->
            <Border Grid.Column="1" Background="#ECEEF2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGE DISPLAY" Foreground="#9098AA" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0"/>

                    </Border>
                    <Grid Grid.Row="1" x:Name="imageContainer">
                        <Image x:Name="imgDisplay" Stretch="Uniform" StretchDirection="Both"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SizeChanged="ImgDisplay_SizeChanged"/>
                        <Canvas x:Name="annotationCanvas" Background="Transparent" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MouseLeftButtonDown="AnnotationCanvas_MouseDown"
                                MouseMove="AnnotationCanvas_MouseMove"
                                MouseLeftButtonUp="AnnotationCanvas_MouseUp"/>
                        <StackPanel x:Name="txtPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center"
                                       Foreground="#C8CCD8" Margin="0,0,0,14"/>
                            <TextBlock Text="Load images to begin" Foreground="#9098AA" FontSize="14"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="PNG  ·  JPG  ·  BMP" Foreground="#C8CCD8" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Right"
                          VerticalAlignment="Stretch" Background="#DDE0E8"
                          ResizeDirection="Columns" ResizeBehavior="CurrentAndNext"/>

            <!-- RIGHT -->
            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#DDE0E8" BorderThickness="1,0,0,0">
                <Grid>

                    <!-- TRAINING PANEL -->
                    <ScrollViewer x:Name="pnlTraining" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16,16,16,20">
                            <TextBlock Text="TRAINING SETUP" Foreground="#9098AA" FontSize="9"
                                       FontWeight="Bold" Margin="0,0,0,14"/>
                            <Border Background="#FEF9EC" BorderBrush="#F0C830" BorderThickness="1"
                                    CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="ANNOTATION STATUS" Foreground="#9098AA" FontSize="9"
                                               FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtAnnotationStatus" Text="No annotations yet"
                                               Foreground="#D63B3B" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="btnStartTrainingBig" Content="Start Training"
                                    Style="{StaticResource BtnGreen}" Click="StartTraining_Click"
                                    IsEnabled="False" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>
                            <Border Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="1"
                                    CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="txtTrainingStatus" Text="Ready"
                                               Foreground="#9098AA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,7"/>
                                    <ProgressBar x:Name="progressBarTraining" Value="0" Style="{StaticResource PbAmber}"/>
                                </StackPanel>
                            </Border>
                            <Border Height="1" Background="#DDE0E8" Margin="0,0,0,14"/>
                            <TextBlock Text="ANNOTATION TOOLS" Foreground="#9098AA" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                           
                            <Border Height="1" Background="#DDE0E8" Margin="0,14"/>
                            <TextBlock Text="TRAINING PARAMETERS" Foreground="#9098AA" FontSize="9" FontWeight="Bold" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Epochs" Foreground="#5A6070" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" x:Name="txtEpochs" Text="50" Style="{StaticResource TxtClean}" Height="30"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Batch Size" Foreground="#5A6070" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" x:Name="txtBatchSize" Text="32" Style="{StaticResource TxtClean}" Height="30"/>
                            </Grid>
                            <Border Height="1" Background="#DDE0E8" Margin="0,0,0,14"/>
                            <TextBlock Text="MODEL" Foreground="#9098AA" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Save" Style="{StaticResource BtnGhost}" Click="SaveModel_Click" Height="30" FontSize="12"/>
                                <Button Grid.Column="2" Content="Grab" Style="{StaticResource BtnGhost}" Click="Grab_Click" Height="30" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- INFERENCE PANEL -->
                    <ScrollViewer x:Name="pnlInference" Visibility="Visible"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16,16,16,20">
                            <TextBlock Text="OCR INFERENCE" Foreground="#9098AA" FontSize="9"
                                       FontWeight="Bold" Margin="0,0,0,14"/>
                            <Button x:Name="btnRunInference" Content="Run OCR on Image"
                                    Style="{StaticResource BtnPrimary}" Click="RunInference_Click"
                                    HorizontalAlignment="Stretch" Height="40" FontSize="13" Margin="0,0,0,10"/>
                            <ProgressBar x:Name="progressBar" Value="0" Style="{StaticResource PbAmber}" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtStatus" Text="Ready" Foreground="#9098AA" FontSize="11" Margin="0,0,0,14"/>
                            <Border Height="1" Background="#DDE0E8" Margin="0,0,0,14"/>
                            <TextBlock Text="RESULT" Foreground="#9098AA" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="1"
                                    CornerRadius="4" Padding="14" Margin="0,0,0,8" MinHeight="64">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="180">
                                    <TextBox x:Name="txtResult" Text="—" Foreground="#1A1D23"
                                             Background="Transparent" BorderThickness="0"
                                             IsReadOnly="False" TextWrapping="Wrap"
                                             FontSize="28" FontWeight="SemiBold" FontFamily="Consolas"
                                             HorizontalAlignment="Stretch"/>
                                </ScrollViewer>
                            </Border>
                            <Border Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="1"
                                    CornerRadius="4" Padding="12,9" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtConfidence" Text="Confidence: —"
                                               Foreground="#5A6070" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="txtDecision" Text="—"
                                               Foreground="#9098AA" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#DDE0E8" Margin="0,0,0,14"/>
                            <TextBlock Text="DECISION" Foreground="#9098AA" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Accept" Click="Accept_Click"
                                        Height="36" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                        Background="#18A058" Foreground="White" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#14834A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Grid.Column="2" Content="Reject" Click="Reject_Click"
                                        Height="36" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                                        Background="#D63B3B" Foreground="White" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#B83030"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            <Border Height="1" Background="#DDE0E8" Margin="0,0,0,14"/>
                            <TextBlock Text="MODEL" Foreground="#9098AA" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Save" Style="{StaticResource BtnGhost}" Click="SaveModel_Click" Height="30" FontSize="12"/>
                                <Button Grid.Column="2" Content="Start" Style="{StaticResource BtnGhost}" Click="LoadModel_Click" Height="30" FontSize="12"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="41*"/>
                                    <ColumnDefinition Width="89*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="2" Content="Grab" Style="{StaticResource BtnGhost}" Click="Grab_Click" Height="30" FontSize="12" Grid.ColumnSpan="2"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#F7F8FA" BorderBrush="#DDE0E8" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="5" Height="2
" Fill="#18A058" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="#9098AA" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="PixTech DLS v2.0" Foreground="#C8CCD8" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>