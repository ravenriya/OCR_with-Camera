        <!-- ============ PALETTE ============ -->
        <SolidColorBrush x:Key="BrushBg"            Color="#D6D6CE"/>
        <SolidColorBrush x:Key="BrushSurface"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt"     Color="#3B3D42"/>
        <SolidColorBrush x:Key="BrushBorder"         Color="#0D0B0D"/>
        <SolidColorBrush x:Key="BrushBorderStrong"   Color="#9C9C90"/>

        <SolidColorBrush x:Key="BrushTextPrimary"    Color="#0D0B0D"/>
        <SolidColorBrush x:Key="BrushTextSecondary"  Color="#1B1B1B"/>
        <SolidColorBrush x:Key="BrushTextMuted"      Color="#6B675E"/>

        <SolidColorBrush x:Key="BrushDark"           Color="#0D0B0D"/>
        <SolidColorBrush x:Key="BrushDarkHover"      Color="#232323"/>

        <SolidColorBrush x:Key="BrushAccentGold"       Color="#F2BD1D"/>
        <SolidColorBrush x:Key="BrushAccentGoldSoft"   Color="#4DD6C313"/>
        <SolidColorBrush x:Key="BrushAccentGoldBorder" Color="#E8DA6B"/>
        <SolidColorBrush x:Key="BrushAccentGoldText"   Color="#5C5200"/>

        <SolidColorBrush x:Key="BrushSuccess"        Color="#1E9E5A"/>
        <SolidColorBrush x:Key="BrushSuccessHover"   Color="#17824A"/>
        <SolidColorBrush x:Key="BrushDanger"         Color="#D64545"/>
        <SolidColorBrush x:Key="BrushDangerHover"    Color="#B83636"/>
        <SolidColorBrush x:Key="BrushDangerSoft"     Color="#FBEAEA"/>
        <SolidColorBrush x:Key="BrushDangerBorder"   Color="#F0BFBF"/>
       

        <SolidColorBrush x:Key="BrushCard" Color="#EDEBE6"/>

        <DropShadowEffect x:Key="CardShadow" Color="#000000" Opacity="0.06"
                           BlurRadius="12" ShadowDepth="2" Direction="270"/>

      

        <!-- ============ BUTTONS ============ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushDark}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushAccentGold}"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Height"            Value="38"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushDarkHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushBorder}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushBorderStrong}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="Medium"/>
            <Setter Property="Height"            Value="34"/>
            <Setter Property="Padding"           Value="14,0"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BrushBorder}"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="6" ShadowDepth="1" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="{StaticResource BrushAccentGoldSoft}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrushAccentGoldBorder}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushSuccess}"/>
            <Setter Property="Foreground"        Value="#FFFFFF"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Height"            Value="40"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushSuccessHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushBorder}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnWarn" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushAccentGoldText}"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Height"            Value="32"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BrushAccentGoldBorder}"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushAccentGoldSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushDanger}"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Height"            Value="32"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BrushDangerBorder}"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushDangerSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accept / Reject -->
        <Style x:Key="BtnAccept" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushSuccess}"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushSuccessHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnReject" TargetType="Button">
            <Setter Property="Background"        Value="{StaticResource BrushDanger}"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushDangerHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ MODE TOGGLE ============ -->

        <Style x:Key="RadioMode" TargetType="RadioButton">
            <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushSurface}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushSurface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ INPUTS ============ -->

        <Style x:Key="TxtClean" TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,5"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="SelectionBrush"    Value="{StaticResource BrushAccentGold}"/>
            <Setter Property="SelectionOpacity"  Value="0.35"/>
            <Setter Property="CaretBrush"         Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrushAccentGold}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ LISTS ============ -->

        <Style x:Key="LbClean" TargetType="ListBox">
            <Setter Property="Background"      Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="LbItem" TargetType="ListBoxItem">
            <Setter Property="Foreground"                 Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Padding"                    Value="12,9"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="{StaticResource BrushAccentGoldSoft}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrushAccentGoldBorder}"/>
                                <Setter Property="Foreground"  Value="{StaticResource BrushAccentGoldText}"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ PROGRESS ============ -->

        <Style x:Key="PbAmber" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Background"      Value="{StaticResource BrushSurfaceAlt}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushAccentGold}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left" CornerRadius="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ SCROLLBARS ============ -->

        <Style x:Key="CleanScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource BrushBorderStrong}" CornerRadius="4" Margin="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CleanScrollThumb}"/>
                                </Track.Thumb>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" Width="0" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" Width="0" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Assets/logo.png" Height="34" Stretch="Uniform" Margin="0,0,12,0"/>
                    <Border Width="1" Height="26" Background="{StaticResource BrushBorder}" Margin="0,0,12,0"/>
                    <TextBlock Text="OCR Studio" Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource BrushSurfaceAlt}"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        CornerRadius="6" Height="34" Width="290" HorizontalAlignment="Center" Padding="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" x:Name="rbInferenceMode" Content="Inference Mode"
                                     GroupName="AppMode" IsChecked="True" Checked="ModeChanged"
                                     Style="{StaticResource RadioMode}"
                                     HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <RadioButton Grid.Column="1" x:Name="rbTrainingMode" Content="Training Mode"
                                     GroupName="AppMode" Checked="ModeChanged"
                                     Style="{StaticResource RadioMode}"
                                     HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource BrushAccentGoldSoft}"
                        BorderBrush="{StaticResource BrushAccentGoldBorder}" BorderThickness="1"
                        CornerRadius="6" Padding="12,5" VerticalAlignment="Center">
                    <TextBlock x:Name="txtMode" Text="INFERENCE MODE"
                               Foreground="{StaticResource BrushAccentGoldText}" FontSize="10" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="{StaticResource BrushSurface}"
        BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Button x:Name="btnLoadFiles" Style="{StaticResource BtnGhost}" Click="LoadFiles_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📄" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Load Files" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnLoadFolder" Style="{StaticResource BtnGhost}" Click="LoadFolder_Click" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="13" Margin="0,0,7,0"/>
                        <TextBlock Text="Load Folder" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Height="18" Background="{StaticResource BrushBorder}" Margin="0,0,14,0"/>
                <Button x:Name="btnAnnotate"         Content="Annotate"       Style="{StaticResource BtnGhost}"   Click="Annotate_Click"         Visibility="Collapsed" IsEnabled="False" Margin="0,0,6,0"/>
                <Button x:Name="btnCheckAnnotations" Content="Refresh"         Style="{StaticResource BtnGhost}"   Click="CheckAnnotations_Click" Visibility="Collapsed" Margin="0,0,6,0"/>

            </StackPanel>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="160"/>
                <ColumnDefinition Width="*"   MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300" MinWidth="260" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Grid.Column="0" Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGES" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="lstImages"
                             Style="{StaticResource LbClean}"
                             ItemContainerStyle="{StaticResource LbItem}"
                             SelectionChanged="ImageList_SelectionChanged"/>
                    <Border Grid.Row="2" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Padding="14,0">
                        <TextBlock x:Name="txtImageCount" Text="0 images" Foreground="{StaticResource BrushTextMuted}" FontSize="10" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- CENTER -->
            <Border Grid.Column="1" Background="{StaticResource BrushSurfaceAlt}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGE DISPLAY" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-0.357"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Border>
                    
                    <Grid Grid.Row="1" x:Name="imageContainer" Cursor="Hand" MouseLeftButtonDown="ImageContainer_MouseLeftButtonDown">

                        <Image x:Name="imgDisplay" Stretch="Uniform" StretchDirection="Both"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SizeChanged="ImgDisplay_SizeChanged"/>
                        <Canvas x:Name="annotationCanvas" Background="Transparent" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MouseLeftButtonDown="AnnotationCanvas_MouseDown"
                                MouseMove="AnnotationCanvas_MouseMove"
                                MouseLeftButtonUp="AnnotationCanvas_MouseUp"/>
                        <StackPanel x:Name="txtPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrushBorderStrong}" Margin="0,0,0,14"/>
                            <TextBlock Text="Load images to begin" Foreground="{StaticResource BrushTextMuted}" FontSize="14"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="PNG  ·  JPG  ·  BMP" Foreground="{StaticResource BrushBorderStrong}" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            
            <GridSplitter Grid.Column="2"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BrushBorderStrong}"
                          Cursor="SizeWE"
                          ShowsPreview="True"/>

            <!-- RIGHT -->
            <Border Grid.Column="3" Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1,0,0,0">
                <Grid>

                    <!-- TRAINING PANEL -->
                    <ScrollViewer x:Name="pnlTraining" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16,16,16,20">
                            <TextBlock Text="TRAINING SETUP" Foreground="{StaticResource BrushTextMuted}" FontSize="9"
                                       FontWeight="Bold" Margin="0,0,0,14"/>
                            <Border Background="{StaticResource BrushAccentGoldSoft}" BorderBrush="{StaticResource BrushAccentGoldBorder}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,0,0,12" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="ANNOTATION STATUS" Foreground="{StaticResource BrushTextMuted}" FontSize="9"
                                               FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtAnnotationStatus" Text="No annotations yet"
                                               Foreground="{StaticResource BrushDanger}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="btnStartTrainingBig" Content="Start Training"
                                    Style="{StaticResource BtnGreen}" Click="StartTraining_Click"
                                    IsEnabled="False" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>
                            <Border Background="{StaticResource BrushBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="txtTrainingStatus" Text="Ready"
                                               Foreground="{StaticResource BrushTextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,7"/>
                                    <ProgressBar x:Name="progressBarTraining" Value="0" Style="{StaticResource PbAmber}"/>
                                </StackPanel>
                            </Border>
                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,14"/>
                            <TextBlock Text="ANNOTATION TOOLS" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,14"/>
                            <TextBlock Text="TRAINING PARAMETERS" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Epochs" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" x:Name="txtEpochs" Text="50" Style="{StaticResource TxtClean}" Height="30"/>
                            </Grid>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Batch Size" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox   Grid.Column="1" x:Name="txtBatchSize" Text="32" Style="{StaticResource TxtClean}" Height="30"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,14"/>
                            <TextBlock Text="MODEL" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Save" Style="{StaticResource BtnGhost}" Click="SaveModel_Click" Height="30" FontSize="12"/>
                                <Button Grid.Column="2" Content="Grab" Style="{StaticResource BtnGhost}" Click="Grab_Click" Height="30" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- INFERENCE PANEL -->
                    <ScrollViewer x:Name="pnlInference" Visibility="Visible"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16,16,16,20">
                            <TextBlock Text="OCR INFERENCE" Foreground="{StaticResource BrushTextMuted}" FontSize="9"
                                       FontWeight="Bold" Margin="0,0,0,14"/>
                            <Button x:Name="btnRunInference" Content="Run OCR on Image"
                                    Style="{StaticResource BtnPrimary}" Click="RunInference_Click"
                                    HorizontalAlignment="Stretch" Height="40" FontSize="13" Margin="0,0,0,10"/>
                            <ProgressBar x:Name="progressBar" Value="0" Style="{StaticResource PbAmber}" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtStatus" Text="Ready" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,14" Height="15"/>
                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,14"/>
                            <TextBlock Text="RESULT" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="{StaticResource BrushBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                    CornerRadius="6" Padding="14" Margin="0,0,0,8" MinHeight="64" Effect="{StaticResource CardShadow}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="180">
                                    <TextBox x:Name="txtResult" Text="—" Foreground="{StaticResource BrushTextPrimary}"
                                         Background="Transparent" BorderThickness="0"
                                         SelectionBrush="{StaticResource BrushAccentGold}" SelectionOpacity="0.35"
                                         IsReadOnly="False" TextWrapping="Wrap"
                                         FontSize="28" FontWeight="SemiBold" FontFamily="Consolas"
                                         HorizontalAlignment="Stretch"/>
                                                    </ScrollViewer>         
                            </Border>
                            <Border Background="{StaticResource BrushBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,9" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtConfidence" Text="Confidence: —"
                                               Foreground="{StaticResource BrushTextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="txtDecision" Text="—"
                                               Foreground="{StaticResource BrushTextMuted}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,14"/>
                            <TextBlock Text="DECISION" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Accept" Click="Accept_Click"
                                        Style="{StaticResource BtnAccept}" Height="36"/>
                                <Button Grid.Column="2" Content="Reject" Click="Reject_Click"
                                        Style="{StaticResource BtnReject}" Height="36"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,14"/>
                            <TextBlock Text="MODEL" Foreground="{StaticResource BrushTextMuted}" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Save" Style="{StaticResource BtnGhost}" Click="SaveModel_Click" Height="30" FontSize="12"/>
                                <Button Grid.Column="2" Content="Start" Style="{StaticResource BtnGhost}" Click="LoadModel_Click" Height="30" FontSize="12"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="2" Content="Grab" Style="{StaticResource BtnGhost}" Click="Grab_Click" Height="30" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="{StaticResource BrushBg}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource BrushSuccess}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="{StaticResource BrushTextMuted}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="PixTech DLS v2.0" Foreground="{StaticResource BrushBorderStrong}" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>