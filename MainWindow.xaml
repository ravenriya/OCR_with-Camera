<Window x:Class="PixtechApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixTech Deep Learning Studio"
        Height="860" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F4F4"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style x:Key="BtnYellow" TargetType="Button">
            <Setter Property="Background" Value="#F5C400"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E6B800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#DDDDDD"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGray" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFBEB"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F5C400"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#16A34A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#DDDDDD"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnOrange" TargetType="Button">
            <Setter Property="Background" Value="#FFF3E0"/>
            <Setter Property="Foreground" Value="#E65100"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFCC80"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFE0B2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnRed" TargetType="Button">
            <Setter Property="Background" Value="#FFF0F0"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioMode" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5C400"/>
                                <Setter Property="Foreground" Value="#111111"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF8DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtLight" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#F5C400"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LbLight" TargetType="ListBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="LbItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#EEEEEE" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFBEB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF8DC"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F5C400"/>
                                <Setter Property="Foreground" Value="#333333"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PbYellow" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="#F5C400"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left" CornerRadius="3"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="Pixtech.png" Height="34" Width="34" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Pixtech" Foreground="#1A1A1A" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Deep Learning Studio" Foreground="#AAAAAA" FontSize="9"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#F4F4F4" BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="20" Height="36" Width="300" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" x:Name="rbInferenceMode" Content="Inference Mode"
                                     GroupName="AppMode" IsChecked="True" Checked="ModeChanged"
                                     Style="{StaticResource RadioMode}"
                                     HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <RadioButton Grid.Column="1" x:Name="rbTrainingMode" Content="Training Mode"
                                     GroupName="AppMode" Checked="ModeChanged"
                                     Style="{StaticResource RadioMode}"
                                     HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#FFF8DC" BorderBrush="#F5C400" BorderThickness="1"
                        CornerRadius="4" Padding="14,6" VerticalAlignment="Center">
                    <TextBlock x:Name="txtMode" Text="INFERENCE MODE"
                               Foreground="#B8860B" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Button x:Name="btnLoadFiles"  Content="📂  Load Files"  Style="{StaticResource BtnGray}" Click="LoadFiles_Click"  Margin="0,0,8,0"/>
                <Button x:Name="btnLoadFolder" Content="📁  Load Folder" Style="{StaticResource BtnGray}" Click="LoadFolder_Click" Margin="0,0,16,0"/>
                <Border Width="1" Background="#E5E5E5" Margin="0,8"/>
                <Button x:Name="btnAutoDetect" Content="⚡  Auto-Detect" Style="{StaticResource BtnGray}" Click="AutoDetectCharacters_Click" Margin="16,0,16,0"/>
                <Border Width="1" Background="#E5E5E5" Margin="0,8"/>
                <TextBlock Text="Tool:" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox x:Name="cmbToolType" Width="120" Height="32" FontSize="12"
                          SelectionChanged="ToolType_SelectionChanged">
                    <ComboBoxItem Content="OCR" IsSelected="True"/>
                    <ComboBoxItem Content="Classification"/>
                    <ComboBoxItem Content="Detection"/>
                </ComboBox>
                <Button x:Name="btnAnnotate"         Content="✏  Annotate"       Style="{StaticResource BtnGray}"   Click="Annotate_Click"         Visibility="Collapsed" IsEnabled="False" Margin="16,0,8,0"/>
                <Button x:Name="btnCheckAnnotations" Content="↻  Refresh"         Style="{StaticResource BtnGray}"   Click="CheckAnnotations_Click" Visibility="Collapsed" Margin="0,0,8,0"/>
                <Button x:Name="btnStartTraining"    Content="🚀  Start Training" Style="{StaticResource BtnYellow}" Click="StartTraining_Click"    Visibility="Collapsed" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Image list -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGES" Foreground="#F5C400" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="lstImages"
                             Style="{StaticResource LbLight}"
                             ItemContainerStyle="{StaticResource LbItem}"
                             SelectionChanged="ImageList_SelectionChanged"/>
                    <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Padding="14,0">
                        <TextBlock x:Name="txtImageCount" Text="Images: 0"
                                   Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- CENTER: Image display -->
            <!-- CENTER: Image display -->
            <Border Grid.Column="1" Background="#E8E8E8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
                        <TextBlock Text="IMAGE DISPLAY" Foreground="#F5C400" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="14,0"/>
                    </Border>
                    <Grid Grid.Row="1" x:Name="imageContainer">
                        <Image x:Name="imgDisplay"
                               Stretch="Uniform"
                               StretchDirection="Both"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               MaxWidth="{Binding ActualWidth, ElementName=imageContainer}"
                               MaxHeight="{Binding ActualHeight, ElementName=imageContainer}"/>
                        <Canvas x:Name="annotationCanvas"
                                Background="Transparent"
                                Visibility="Collapsed"
                                MouseLeftButtonDown="AnnotationCanvas_MouseDown"
                                MouseMove="AnnotationCanvas_MouseMove"
                                MouseLeftButtonUp="AnnotationCanvas_MouseUp"/>
                        <StackPanel x:Name="txtPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Foreground="#CCCCCC"/>
                            <TextBlock Text="Load images to begin" Foreground="#BBBBBB" FontSize="14"
                                       HorizontalAlignment="Center" Margin="0,10,0,4"/>
                            <TextBlock Text="PNG  ·  JPG  ·  BMP" Foreground="#CCCCCC" FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- RIGHT: Training + Inference panels -->
            <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="1,0,0,0">
                <Grid>

                    <!-- TRAINING PANEL -->
                    <ScrollViewer x:Name="pnlTraining" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16,16,16,20">
                            <TextBlock Text="TRAINING SETUP" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                            <Border Background="#FFFBEB" BorderBrush="#F5C400" BorderThickness="1"
                                    CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="ANNOTATION STATUS" Foreground="#B8860B" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="txtAnnotationStatus" Text=" No annotations yet"
                                               Foreground="#DC2626" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="btnStartTrainingBig" Content="🚀  START TRAINING NOW"
                                    Style="{StaticResource BtnGreen}" Click="StartTraining_Click"
                                    IsEnabled="False" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>
                            <Border Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="1"
                                    CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock x:Name="txtTrainingStatus" Text="Ready"
                                               Foreground="#888888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <ProgressBar x:Name="progressBarTraining" Value="0" Style="{StaticResource PbYellow}"/>
                                </StackPanel>
                            </Border>
                            <Border Height="1" Background="#EEEEEE" Margin="0,4,0,12"/>
                            <TextBlock Text="ANNOTATION TOOLS" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Button Content="⚡  Fix Mixed Annotations"  Style="{StaticResource BtnOrange}" Click="SeparateAnnotations_Click"          HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                            <Button Content="🗑  Clear Current Image"    Style="{StaticResource BtnOrange}" Click="ClearCurrentImageAnnotations_Click" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                            <Button Content="🗑  Clear ALL Annotations"  Style="{StaticResource BtnRed}"    Click="ClearAllAnnotations_Click"          HorizontalAlignment="Stretch"/>
                            <Border Height="1" Background="#EEEEEE" Margin="0,12"/>
                            <TextBlock Text="TRAINING PARAMETERS" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Epochs" Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtEpochs" Text="50" Style="{StaticResource TxtLight}" Height="28"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Batch Size" Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtBatchSize" Text="32" Style="{StaticResource TxtLight}" Height="28"/>
                            </Grid>
                            <Border Height="1" Background="#EEEEEE" Margin="0,4,0,12"/>
                            <TextBlock Text="MODEL" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="💾 Save" Style="{StaticResource BtnGray}" Click="SaveModel_Click" Height="30" FontSize="11"/>
                                <Button Grid.Column="2" Content="📂 Load" Style="{StaticResource BtnGray}" Click="LoadModel_Click" Height="30" FontSize="11"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- INFERENCE PANEL -->
                    <ScrollViewer x:Name="pnlInference" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16,16,16,20">
                            <TextBlock Text="OCR INFERENCE" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                            <Button x:Name="btnRunInference" Content="▶  Run OCR on Image"
                                    Style="{StaticResource BtnYellow}" Click="RunInference_Click"
                                    HorizontalAlignment="Stretch" Height="42" FontSize="13" Margin="0,0,0,10"/>
                            <ProgressBar x:Name="progressBar" Value="0" Style="{StaticResource PbYellow}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtStatus" Text="Ready" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,12"/>
                            <Border Height="1" Background="#EEEEEE" Margin="0,0,0,12"/>
                            <TextBlock Text="RESULT" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="1"
                                    CornerRadius="4" Padding="12" Margin="0,0,0,8">
                                <TextBox x:Name="txtResult" Text="—"
                                         Foreground="#1A1A1A" Background="Transparent"
                                         BorderThickness="0" IsReadOnly="True"
                                         TextWrapping="Wrap" FontSize="24" FontWeight="Bold" FontFamily="Consolas"/>
                            </Border>
                            <Border Background="#FAFAFA" BorderBrush="#E5E5E5" BorderThickness="1"
                                    CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtConfidence" Text="Confidence: —" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="txtDecision" Text="—" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#EEEEEE" Margin="0,0,0,12"/>
                            <TextBlock Text="DECISION" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="✓  Accept" Click="Accept_Click" Height="36" FontSize="13"
                                        FontWeight="Bold" Cursor="Hand" Background="#22C55E" Foreground="White" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#16A34A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Grid.Column="2" Content="✕  Reject" Click="Reject_Click" Height="36" FontSize="13"
                                        FontWeight="Bold" Cursor="Hand" Background="#EF4444" Foreground="White" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#DC2626"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            <Border Height="1" Background="#EEEEEE" Margin="0,0,0,12"/>
                            <TextBlock Text="MODEL" Foreground="#F5C400" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="💾 Save" Style="{StaticResource BtnGray}" Click="SaveModel_Click" Height="30" FontSize="11"/>
                                <Button Grid.Column="2" Content="📂 Load" Style="{StaticResource BtnGray}" Click="LoadModel_Click" Height="30" FontSize="11"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Border>

        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Pixtech DLS v2.0" Foreground="#CCCCCC" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>