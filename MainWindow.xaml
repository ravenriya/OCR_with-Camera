<Window x:Class="CognexStyleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PixTech Deep Learning" 
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🎯" FontSize="30" Margin="0,0,15,0"/>
                    <TextBlock Text="PixTech Deep Learning Studio" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnLoadFiles" Content="Load Files" Width="150" Height="40" Margin="5" Background="#0078D4" Foreground="White" Click="LoadFiles_Click"/>
                    <Button x:Name="btnLoadFolder" Content="Load Folder" Width="150" Height="40" Margin="5" Background="#0078D4" Foreground="White" Click="LoadFolder_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="Tool:" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbToolType" Width="300" Height="35" Margin="5" SelectionChanged="ToolType_SelectionChanged">
                        <ComboBoxItem Content="OCR" IsSelected="True"/>
                        <ComboBoxItem Content="Defects"/>
                        <ComboBoxItem Content="Classification"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Images" FontWeight="Bold"/>
                    <ListBox x:Name="lstImages" Grid.Row="1" SelectionChanged="ImageList_SelectionChanged"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" Padding="15" Margin="5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Image Display" FontWeight="Bold"/>
                    <Border Grid.Row="1" Background="#F0F0F0">
                        <Grid>
                            <TextBlock x:Name="txtPlaceholder" Text="Load images" FontSize="20" Foreground="#AAA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="imgDisplay" Stretch="Uniform" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" Padding="15">
                <StackPanel>
                    <TextBlock Text="TRAINING" FontWeight="Bold" FontSize="14"/>
                    <TextBlock x:Name="txtStatus" Text="Ready" Margin="0,10"/>
                    <ComboBox x:Name="cmbEpochs" Height="32" Margin="0,10" SelectedIndex="1">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="50"/>
                        <ComboBoxItem Content="100"/>
                    </ComboBox>
                    <Button x:Name="btnTrain" Content="TRAIN" Height="45" Margin="0,15" Background="#28A745" Foreground="White" Click="Train_Click"/>
                    <ProgressBar x:Name="progressBar" Height="25" Value="0" Margin="0,10"/>
                    <TextBlock x:Name="txtEpoch" Text="Epoch: 0/50" FontSize="10"/>
                    <Button x:Name="btnSaveModel" Content="Save" Height="35" Margin="0,15,0,5" Click="SaveModel_Click"/>
                    <Button x:Name="btnLoadModel" Content="Load" Height="35" Click="LoadModel_Click"/>
                    <TextBlock Text="RESULTS" FontWeight="Bold" Margin="0,20,0,10"/>
                    <Border Background="#F9F9F9" Padding="10">
                        <StackPanel>
                            <TextBlock x:Name="txtResult" Text="---" FontSize="18" Foreground="Blue" FontWeight="Bold"/>
                            <TextBlock x:Name="txtConfidence" Text="Confidence: ---" FontSize="12" Margin="0,5"/>
                            <TextBlock x:Name="txtDecision" Text="---" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Accept" Height="40" Background="#28A745" Foreground="White" Click="Accept_Click"/>
                        <Button Grid.Column="1" Content="Reject" Height="40" Background="#DC3545" Foreground="White" Margin="5,0,0,0" Click="Reject_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtStatusBar" Text="Ready" Foreground="White" FontSize="11" Margin="0,0,20,0"/>
                <TextBlock x:Name="txtImageCount" Text="Images: 0" Foreground="White" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>